# ══════════════════════════════════════════════════════════════
# .env.example — copy this to .env and fill in your values
# NEVER commit .env to GitHub — it is in .gitignore
# ══════════════════════════════════════════════════════════════

# Your Anthropic API key — get it from console.anthropic.com
ANTHROPIC_API_KEY=sk-ant-your-key-here

# GitHub personal access token — needs repo and actions:read scope
# Create at: github.com/settings/tokens
GITHUB_TOKEN=ghp_your-token-here

# AWS configuration — must match what you used in aws configure
AWS_REGION=us-east-1

# The S3 bucket name you created in Phase 2 — replace YOUR_NAME
TF_STATE_BUCKET=platform-demo-tfstate-YOUR_NAME

# Your GitHub repo in owner/repo format
GITHUB_REPO=NaylorRobinson/platform-engineering-demo
